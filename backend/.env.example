PORT=8788
WORKER_POLL_INTERVAL_MS=1500
WORKER_CONCURRENCY=3
WORKER_SIGNING_SECRET=generate-a-long-random-shared-secret
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site
HERMES_BIN=/absolute/path/to/hermes
HERMES_MODEL=
LINKUP_API_KEY=replace-with-linkup-key
TEMPLATE_LIBRARY_PATH=/absolute/path/to/approved/templates

# Wrangler may use an existing OAuth login. Set these for unattended or
# multi-account deployments; never commit the API token.
CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
CLOUDFLARE_API_TOKEN=
