# Copy the applicable values into backend/.env and frontend/.env.local.
CONVEX_URL=
CONVEX_SITE_URL=
VITE_CONVEX_URL=
WORKER_SIGNING_SECRET=
WORKER_POLL_INTERVAL_MS=1500
WORKER_CONCURRENCY=3
HERMES_BIN=/home/ubuntu/.local/bin/hermes
HERMES_MODEL=
LINKUP_API_KEY=
# Absolute path to the approved landing-page template/prompt library on the VPS.
TEMPLATE_LIBRARY_PATH=/home/ubuntu/projects/hackathon/templates
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Hosted Convex variables (set with `npx convex env set`, not in frontend files).
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_PRODUCT_ID=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
BILLING_BYPASS_OWNER_KEYS=
